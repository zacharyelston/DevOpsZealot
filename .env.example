# DevOpsZealot Environment Configuration

# API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GITHUB_TOKEN=your-github-token-here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=optional-redis-password

# Docker Configuration
DOCKER_SOCKET=/var/run/docker.sock
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_QUOTA=50000
CONTAINER_TIMEOUT_SECONDS=300

# AI Configuration
DEFAULT_AI_MODEL=gpt-4
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4000
AI_REQUEST_TIMEOUT=60

# Continue.dev Integration
ENABLE_CONTINUE_INTEGRATION=true
CONTINUE_CONFIG_PATH=~/.continue/config.json
CONTINUE_API_URL=http://localhost:11434
CONTINUE_DEFAULT_MODEL=gpt-4
USE_LOCAL_MODELS=false
LOCAL_MODEL_PATH=
PREFER_LOCAL_MODELS=false

# Security Configuration
ALLOWED_REPOSITORIES=https://github.com/zacharyelston/*,https://github.com/yourorg/*
MAX_FILE_SIZE_MB=10
ENABLE_SECURITY_SCANNING=true
API_KEY_HEADER=X-API-Key

# Validation Configuration
ENABLE_SYNTAX_VALIDATION=true
ENABLE_SECURITY_VALIDATION=true
VALIDATION_TIMEOUT_SECONDS=120

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# MCP Server Configuration (optional)
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost

# Feature Flags
ENABLE_COST_ANALYSIS=true
ENABLE_DRIFT_DETECTION=true
ENABLE_AUTO_ROLLBACK=false

# Model Routing Preferences (optional)
# Comma-separated list of model:task_type pairs
# MODEL_ROUTING=gpt-4:terraform,claude-3:validation,gpt-4:documentation
