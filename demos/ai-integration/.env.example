# DevOpsZealot AI Integration Demo - Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Key (Required for OpenAI models like GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Required for Anthropic models like Claude)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Token (For repository operations)
GITHUB_TOKEN=your_github_token_here

# AI Model Configuration
# Defaults will be used if not specified
# For OpenAI: gpt-4, gpt-3.5-turbo, etc.
# For Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229, etc.
AI_MODEL=gpt-4

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Enable verbose logging (true/false)
VERBOSE_LOGGING=true
